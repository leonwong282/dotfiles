# ~/.zshenv - Minimal environment loaded by every zsh invocation.
#
# This file is sourced for interactive shells, login shells, scripts, and
# `zsh -c` commands. Keep it limited to cheap, side-effect-free defaults.

# Follow the XDG base directory layout so tool-specific state does not spread
# across the home directory.
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"

# Central location for all modular zsh configuration files.
export ZSH_CONFIG_DIR="${ZSH_CONFIG_DIR:-$XDG_CONFIG_HOME/zsh}"
