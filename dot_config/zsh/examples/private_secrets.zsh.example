# ~/.config/zsh/secrets.zsh - local shell secrets.
#
# Copy this file to ~/.config/zsh/secrets.zsh and fill in local values. Do not
# commit real API keys, tokens, passwords, or private endpoints.

# Keep exports simple. Complex secret loading should move to an encrypted
# chezmoi template or a password manager CLI later.
# export ANTHROPIC_API_KEY=""
# export ANTHROPIC_BASE_URL=""
# export OPENAI_API_KEY=""
