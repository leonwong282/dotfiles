#!/usr/bin/env bash
set -euo pipefail

# Brewfile checksum: {{ include "Brewfile" | sha256sum }}

if [[ "$(uname -s)" != "Darwin" ]]; then
  echo "Skipping Homebrew setup: this script is intended for macOS."
  exit 0
fi

if [[ "${DOTFILES_RUN_HOMEBREW_BUNDLE:-0}" != "1" ]]; then
  echo "Skipping Homebrew bundle lifecycle step."
  echo "To opt in for one apply, run: DOTFILES_RUN_HOMEBREW_BUNDLE=1 chezmoi apply"
  exit 0
fi

echo "Setting up Homebrew packages..."

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew is not installed. Install it manually before running this lifecycle step." >&2
  exit 1
fi

if [[ -x /opt/homebrew/bin/brew ]]; then
  eval "$(/opt/homebrew/bin/brew shellenv)"
elif [[ -x /usr/local/bin/brew ]]; then
  eval "$(/usr/local/bin/brew shellenv)"
fi

if ! command -v brew >/dev/null 2>&1; then
  echo "Homebrew was not found after installation." >&2
  exit 1
fi

brew bundle --file="${HOME}/Brewfile"

echo "Homebrew bundle complete."
