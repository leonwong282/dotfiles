# ~/.zshrc - Interactive shell entrypoint.

[[ -o interactive ]] || return

: "${ZSH_CONFIG_DIR:=${XDG_CONFIG_HOME:-$HOME/.config}/zsh}"

_zsh_source() {
    local file="$ZSH_CONFIG_DIR/$1"
    [[ -r "$file" ]] && source "$file"
}

_zsh_source path.zsh
_zsh_source env.zsh
_zsh_source options.zsh
_zsh_source completion.zsh
_zsh_source aliases.zsh
_zsh_source functions.zsh
_zsh_source prompt.zsh
_zsh_source secrets.zsh
_zsh_source local.zsh

unset -f _zsh_source
