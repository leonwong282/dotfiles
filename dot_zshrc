# ~/.zshrc - Interactive shell configuration
# Loaded for every new terminal window

# ============================================
# Environment Variables - API Keys, etc.
# ============================================

# Claude Code
export ANTHROPIC_API_KEY=sk-xxx
export ANTHROPIC_BASE_URL=https://xxx

# ============================================
# Environment Variables
# ============================================

# Default editors
export EDITOR="vim"   # Or nvim, vim, nano
export VISUAL="code --wait"

# Language and locale
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# History settings
export HISTSIZE=10000
export SAVEHIST=10000
export HISTFILE="$HOME/.zsh_history"

# Less pager settings
export LESS="-R"              # Enable color in less
export PAGER="less"

# ============================================
# Aliases
# ============================================

# Quick directory navigation
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias ~='cd ~'

# List files with details
alias ll='ls -la'
alias la='ls -A'
alias l='ls -CF'

# Git shortcuts
alias gs='git status'
alias ga='git add'
alias gc='git commit'
alias gp='git push'
alias gl='git pull'
alias gd='git diff'
alias gco='git checkout'
alias gb='git branch'
alias glog='git log --oneline --graph --decorate'

# Confirm before overwriting
alias cp='cp -i'
alias mv='mv -i'
alias rm='rm -i'

# Use modern tools if installed
alias cat='bat'           # bat: cat with syntax highlighting
alias ls='eza'             # eza: modern ls
alias find='fd'            # fd: modern find
alias grep='rg'            # ripgrep: fast grep

# Show PATH entries one per line
alias path='echo $PATH | tr ":" "\n"'

# Get public IP
alias myip='curl ifconfig.me'

# Clear terminal
alias c='clear'

# Edit and reload zshrc
alias zshconfig='vim ~/.zshrc'
alias reload='source ~/.zshrc'

# ============================================
# Functions
# ============================================

# Create directory and cd into it
# Usage: mkcd my-new-project
mkcd() {
    mkdir -p "$1" && cd "$1"
}

# Extract any archive:
# Usage: extract archive.tar.gz
extract() {
    if [[ -f "$1" ]]; then
        case "$1" in
            *.tar.bz2)   tar xjf "$1"     ;;
            *.tar.gz)    tar xzf "$1"     ;;
            *.tar.xz)    tar xJf "$1"     ;;
            *.bz2)       bunzip2 "$1"     ;;
            *.gz)        gunzip "$1"      ;;
            *.tar)       tar xf "$1"      ;;
            *.zip)       unzip "$1"       ;;
            *.7z)        7z x "$1"        ;;
            *)           echo "Unknown archive format: $1" ;;
        esac
    else
        echo "File not found: $1"
    fi
}

