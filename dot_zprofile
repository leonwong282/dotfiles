# ~/.zprofile - Login shell configuration.
# Keep this small; interactive behavior belongs in ~/.zshrc.

# Login shells need PATH early so GUI-launched terminals can find Homebrew and
# user-local commands before .zshrc loads.
if [[ -r "${ZSH_CONFIG_DIR:-$HOME/.config/zsh}/path.zsh" ]]; then
    source "${ZSH_CONFIG_DIR:-$HOME/.config/zsh}/path.zsh"
fi
