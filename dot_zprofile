# ~/.zprofile - login shell configuration.
#
# Login shells run once when a terminal session starts. Keep this file small:
# it should prepare PATH for GUI-launched terminals, while interactive behavior
# remains in ~/.zshrc.

: "${ZSH_CONFIG_DIR:=${XDG_CONFIG_HOME:-$HOME/.config}/zsh}"

if [[ -r "$ZSH_CONFIG_DIR/lib/source.zsh" ]]; then
    source "$ZSH_CONFIG_DIR/lib/source.zsh"
    zsh_source "lib/guards.zsh"
    zsh_source "lib/path.zsh"
    zsh_source "modules/00-path.zsh"
fi
